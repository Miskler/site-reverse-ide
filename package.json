{
  "name": "site-reverse-ide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"cross-env NODE_ENV=development PORT=3001 tsx watch server/index.ts\" \"vite --port 5173\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production PORT=3000 tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "py:genschema": "python python-server/genschema_server.py"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@xyflow/react": "^12.10.2",
    "fastify": "^5.8.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "write-file-atomic": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
